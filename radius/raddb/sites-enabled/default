server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        filter_username
        preprocess
        chap
        mschap
        suffix
        ntdomain
        sql
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }

        Auth-Type CHAP {
            chap
        }

        Auth-Type MS-CHAP {
            mschap
        }
    }

    preacct {
        preprocess
        acct_unique
        suffix
        ntdomain
    }

    accounting {
        sql
    }

    session {
        sql
    }

    post-auth {
        reply_log
        sql
    }
}
