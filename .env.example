DJANGO_SECRET_KEY=change-me
# Production: set to 0 and set ALLOWED_HOSTS / CSRF_TRUSTED_ORIGINS to your public https origins
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Use https://yourdomain.com in production; comma-separated
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# Coolify / reverse proxy: set to 1 so HTTPS and host are read from X-Forwarded-* headers
# DJANGO_BEHIND_PROXY=0
# Log namespace for Django/Celery line logs (compose sets per-service values; optional override)
# LOG_NAMESPACE=base.django
DJANGO_LOG_LEVEL=INFO
DJANGO_TIME_ZONE=Africa/Accra

# Database: the default `docker compose` stack does not include a Postgres container — set DATABASE_URL
# to your real server (e.g. Coolify managed PG). Optional: discrete POSTGRES_* if you omit DATABASE_URL.
# If both are set, Django uses DATABASE_URL (unless DJANGO_USE_SQLITE=1). Example:
# DATABASE_URL=postgres://user:pass@db-host:5432/ananse_wifi?sslmode=require
# Optional pool tuning when using DATABASE_URL (seconds; 0 = new connection per request, Django default for runserver)
# DATABASE_CONN_MAX_AGE=0
# Testing: `make verify-database-url` uses DATABASE_URL from .env (connect + manage.py check, no migrate).
# `make test` runs pytest with DJANGO_USE_SQLITE=1 in Docker (no embedded Postgres, no remote CREATEDB needed).
POSTGRES_DB=ananse_wifi
POSTGRES_USER=ananse
POSTGRES_PASSWORD=ananse
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
RADIUS_ACCT_SYNC_INTERVAL_SECONDS=30

# FreeRADIUS SQL: same host/db/user/password as in DATABASE_URL (RADIUS does not read DATABASE_URL). Required when using the `radius` service.
RADIUS_DB_HOST=your-pg-host.example
RADIUS_DB_PORT=5432
RADIUS_DB_NAME=ananse_wifi
RADIUS_DB_USER=ananse
RADIUS_DB_PASSWORD=ananse
RADIUS_SQL_DIALECT=postgresql
RADIUS_CLIENT_SECRET=ananse-radius-secret

# Coolify: map HTTP health check to the app (Gunicorn listens on 8000 by default in this project).
# Celery worker and beat should be separate services with the same image/env as the web app.
# FreeRADIUS (if used) is usually a separate service with UDP and DB access aligned to RADIUS_DB_*.
