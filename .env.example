DJANGO_SECRET_KEY=change-me

DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:18080,http://localhost:18080

# Production (HTTPS behind Traefik/Coolify/nginx): trust X-Forwarded-Proto and forward the public Host.
# DJANGO_BEHIND_PROXY=1
# DJANGO_ALLOWED_HOSTS=anansewifi.shrt.fit
# DJANGO_CSRF_TRUSTED_ORIGINS=https://anansewifi.shrt.fit

DJANGO_LOG_LEVEL=INFO
DJANGO_TIME_ZONE=Africa/Accra

POSTGRES_DB=ananse_wifi
POSTGRES_USER=ananse
POSTGRES_PASSWORD=ananse
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Container startup wait for PostgreSQL (see scripts/wait_for_pg_tcp.py). Unset uses defaults.
# PG_WAIT_TIMEOUT_SECONDS=120
# PG_WAIT_FORCE_IPV4=1
# PG_WAIT_SKIP=1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
RADIUS_ACCT_SYNC_INTERVAL_SECONDS=30


RADIUS_SQL_DIALECT=postgresql
RADIUS_CLIENT_SECRET=ananse-radius-secret

# Paystack (hosted checkout for portal “Buy Plan”; use test keys from dashboard)
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_BASE_URL=https://api.paystack.co
# PAYSTACK_CALLBACK_URL=http://localhost:18080/portal/purchase/callback/
# PAYMENT_CURRENCY=GHS
#
# Buy Plan: show interstitial with “Continue to Paystack” (default, better for iOS captive browsers).
# Set to 1 only if you need the old immediate redirect after Paystack initialize (e.g. some tests).
# PURCHASE_CHECKOUT_REDIRECT_DIRECT=0
